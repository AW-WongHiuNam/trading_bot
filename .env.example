# Auto-filled from existing scripts/examples; adjust as needed.
ALPHAVANTAGE_API_KEY=

QDRANT_URL=http://localhost:7500
QDRANT_PATH=qdrant_db
QDRANT_COLLECTION=api_calls
QDRANT_FORCE_MOCK_EMBED=false

OLLAMA_EMBED_URL=http://localhost:11434/api/embed
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_EMBED_RETRIES=4
OLLAMA_EMBED_BACKOFF_SEC=1.0
OLLAMA_EMBED_MIN_INTERVAL_SEC=0.35
OLLAMA_EMBED_TIMEOUT_SEC=90

OLLAMA_COMPLETION_URL=http://localhost:11434/completion
# OLLAMA_CHAT_MODEL=deepseek-r1:latest
OLLAMA_CHAT_MODEL=gemma4:e2b
COMPLETION_MAX_TOKENS=512
LANGGRAPH_RECURSION_LIMIT=20000

CHUNK_SIZE=2000
CHUNK_OVERLAP=400
VECTOR_TOP_K=5

DATA_DIR=data
DEFAULT_OUTPUT_PATH=
