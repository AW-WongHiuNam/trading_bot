# Alpha Vantage
ALPHAVANTAGE_API_KEY=

# SQLite + hnswlib (local)
SQLITE_PATH=vector_store.sqlite
SQLITE_TABLE=api_calls
VECTOR_INDEX_PATH=vector_index.bin
VECTOR_DIM=768
ANN_INDEX_SPACE=ip
ANN_EF=200
ANN_M=16
VECTOR_FORCE_MOCK_EMBED=false

# Ollama embeddings
OLLAMA_EMBED_URL=http://127.0.0.1:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Ollama completion / chat
OLLAMA_COMPLETION_URL=http://127.0.0.1:11434/completion
OLLAMA_CHAT_MODEL=qwen2.5:14b
COMPLETION_MAX_TOKENS=512

# Chunking and retrieval
CHUNK_SIZE=2000
CHUNK_OVERLAP=400
VECTOR_TOP_K=5

# Paths and output
DATA_DIR=data
DEFAULT_OUTPUT_PATH=
